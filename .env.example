# MongoDB Configuration
MONGODB_URI=mongodb://mongodb:27017/keeplocal

# Server Configuration
PORT=5000
NODE_ENV=production
HOST=0.0.0.0
# Direct split/all-in-one access has one internal Nginx hop. Use 2 only when
# one additional trusted reverse proxy (NPM, Traefik, Caddy) sits in front.
TRUST_PROXY=1

# CORS Configuration (comma-separated origins, NO SPACES!)
# Für lokale Entwicklung:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
# Für Nginx Proxy Manager / Production (füge deine Domain hinzu):
# ALLOWED_ORIGINS=https://keeplocal.deine-domain.de,http://localhost:3000
# Für mehrere Domains:
# ALLOWED_ORIGINS=https://keeplocal.example.com,https://notes.example.com,http://localhost:3000

# JWT Authentication (REQUIRED; no reusable default is provided)
# Generiere ein sicheres Secret mit: openssl rand -hex 48
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Optional but recommended: use a separate 32+ character random value.
# Defaults to JWT_SECRET when omitted.
CSRF_SECRET=
# Optional override. Leave empty to detect HTTPS through TRUST_PROXY.
COOKIE_SECURE=

# Exact frontend origin used for OAuth redirects. Match an ALLOWED_ORIGINS entry.
CLIENT_URL=http://localhost:3000

# Whisper model for split-container builds. The all-in-one image defaults to tiny.
# Common values: tiny, base, small, medium, large-v3, turbo
WHISPER_MODEL=base

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
