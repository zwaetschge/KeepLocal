{
  "name": "keeplocal-client",
  "version": "2.0.0",
  "description": "KeepLocal - A Google Keep clone (Client)",
  "private": true,
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/delius-swash-caps": "^5.2.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "dompurify": "^3.0.6"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=development vite --host 0.0.0.0",
    "dev": "cross-env NODE_ENV=development vite --host 0.0.0.0",
    "build": "cross-env NODE_ENV=production vite build",
    "lint": "eslint src",
    "test:regression": "node --test tests/*.test.js",
    "test": "node --test tests/*.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.0.0",
    "vite": "^8.1.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
